{
  "name": "policy-tracker",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "node scripts/dev-wrangler.mjs",
    "dev:next": "next dev",
    "opennext:build": "next build && opennextjs-cloudflare build --skipNextBuild",
    "build": "npm run opennext:build",
    "build:next": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "xlsx": "^0.18.5",
    "@opennextjs/cloudflare": "^1.17.1",
    "drizzle-orm": "^0.44.4",
    "jose": "^6.1.3",
    "next": "16.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260129.0",
    "wrangler": "^4.69.0",
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.35.0",
    "eslint-config-next": "15.5.7",
    "typescript": "^5.8.2"
  }
}
